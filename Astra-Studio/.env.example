# 环境配置示例（复制此文件为 .env 并填入实际值）

# 后端 API 地址（可选，默认 http://localhost:8089/api）
# VITE_API_BASE_URL=https://api.yourdomain.com/api

# 可选：OSS 自定义访问域名（如 CDN 域名或绑定的自定义域名）
# 如果不配置，将使用默认的 OSS 域名：https://{bucket}.{endpoint}/
# VITE_OSS_CUSTOM_DOMAIN=https://cdn.yourdomain.com

# 注意：OSS 密钥已迁移至后端配置，请勿在前端 .env 中填写：
# - VITE_OSS_ACCESS_KEY_ID (已移除，改用后端 oss.access-key-id)
# - VITE_OSS_ACCESS_KEY_SECRET (已移除，改用后端 oss.access-key-secret)
# - VITE_OSS_BUCKET (已移除，改用后端 oss.bucket)
# - VITE_OSS_REGION (已移除，改用后端 oss.region)
# - VITE_OSS_ENDPOINT (已移除，改用后端 oss.endpoint)
#
# 请在 application-local.yaml 中配置：
# oss:
#   access-key-id: your_oss_access_key_id
#   access-key-secret: your_oss_access_key_secret
#   bucket: your_bucket_name
#   region: oss-cn-hangzhou
#   endpoint: https://oss-cn-hangzhou.aliyuncs.com
